{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "docker-build",
			"label": "docker-build",
			"platform": "python",
			"dockerBuild": {
				"tag": "aqui:latest",
				"dockerfile": "${workspaceFolder}/Dockerfile",
				"context": "${workspaceFolder}",
				"pull": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: debug",
			"dependsOn": [
				"docker-build"
			],
			"dockerRun": {
				"image": "aqui:latest",
				"containerName": "aqui-dev",
				"ports": [
					{
						"containerPort": 5002,
						"hostPort": 5002
					}
				],
				"env": {
					"FLASK_APP": "app.py",
					"FLASK_ENV": "development",
					"FLASK_DEBUG": "1"
				},
				"volumes": [
					{
						"localPath": "${workspaceFolder}",
						"containerPath": "/app",
						"permissions": "rw"
					}
				]
			},
			"python": {
				"args": [
					"run",
					//"--no-debugger",
					//"--no-reload",
					"--host",
					"0.0.0.0",
					"--port",
					"5002"
				],
				"module": "flask"
			}
		}
	]
}